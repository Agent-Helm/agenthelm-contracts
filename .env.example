# --- RPC ---
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Deployer ---
# Private key of the deploying account (0x-prefixed). Never commit the real value.
PRIVATE_KEY=

# --- Verification ---
BASESCAN_API_KEY=

# --- Constructor args (Base mainnet canonical addresses) ---
# Wrapped ETH on Base
WETH=0x4200000000000000000000000000000000000006
# Uniswap Permit2 (same address across chains)
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
